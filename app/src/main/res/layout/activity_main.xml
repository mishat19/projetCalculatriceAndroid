<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/titreApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DON CALCULATOR"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✝"
        android:textSize="80sp"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/bouton_jouer"
        android:layout_width="250dp"
        android:layout_height="60dp"
        android:text="@string/test_bouton_jouer"
        android:textSize="20sp"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/test_bouton_highscore"
        android:layout_width="250dp"
        android:layout_height="60dp"
        android:text="@string/test_bouton_highscore"
        android:textSize="20sp"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/test_bouton_settings"
        android:layout_width="250dp"
        android:layout_height="60dp"
        android:text="@string/test_bouton_settings"
        android:textSize="20sp"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CalculatriceActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <!-- ZONE HAUTE : vies + calcul -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- Compteur de score à gauche -->
            <TextView
                android:id="@+id/score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/score_label"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Espace entre le score et les vies -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Vies à droite -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/vie3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/cross" />

                <ImageView
                    android:id="@+id/vie2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/cross" />

                <ImageView
                    android:id="@+id/vie1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/cross" />
            </LinearLayout>
        </LinearLayout>

        <!-- Calcul -->
        <TextView
            android:id="@+id/calcul"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="34sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- RESULTAT -->
    <TextView
        android:id="@+id/resultat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textSize="28sp"
        android:text="" />

    <!-- CLAVIER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/bouton_9"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="9"/>

            <Button android:id="@+id/bouton_8"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="8"/>

            <Button android:id="@+id/bouton_7"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="7"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/bouton_6"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="6"/>

            <Button android:id="@+id/bouton_5"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="5"/>

            <Button android:id="@+id/bouton_4"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="4"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/bouton_3"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="3"/>

            <Button android:id="@+id/bouton_2"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="2"/>

            <Button android:id="@+id/bouton_1"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="1"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/bouton_symbol"
                style="@style/CalculatorButton.Operation"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="+/-"
                android:layout_height="wrap_content"/>

            <Button android:id="@+id/bouton_0"
                style="@style/CalculatorButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="0"/>


            <Button
                android:id="@+id/bouton_delete"
                style="@style/CalculatorButton.Operation"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="⌫"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/bouton_check"
                style="@style/CalculatorButton.Operation"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:text="Vérifier"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    </LinearLayout>

    <!-- Conteneur pour les animations (sera au-dessus du reste) -->
    <FrameLayout
        android:id="@+id/animation_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</FrameLayout>